# ===== Google Sheets connection =====
# อีเมลของ Service Account (ลงท้ายด้วย .iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private key จากไฟล์ JSON ของ Service Account
# วางทั้งก้อนในเครื่องหมายคำพูด และคง \n ไว้ตามเดิม (ห้ามลบ)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...ทั้งก้อน...==\n-----END PRIVATE KEY-----\n"

# Spreadsheet ID (ค่าเริ่มต้นคือชีทที่ตกลงไว้)
SHEET_ID=1NzkfO_G0pa0fZMvuMlIzaLp-oUx5KAat_GVzng5xSKE
